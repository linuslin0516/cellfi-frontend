# ==========================================
# BSC.IO 客戶端 - 生產環境配置
# ==========================================

# 遊戲服務器 URL (改成你的 API 域名)
VITE_SERVER_URL=https://api.yourdomain.com

# 合約地址 (BSC 主網)
VITE_AGAR_TOKEN_ADDRESS=0x...your_token_address
VITE_GAME_VAULT_ADDRESS=0x...your_vault_address

# Coming Soon Mode (set to "true" to disable gameplay, "false" to enable)
VITE_COMING_SOON=true
